# ─────────────────────────────────────────────────────────────────
# Polymarket Bot v5 — Environment Variables
# cp .env.example .env  →  fill in values  →  never commit .env
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────

# Your Magic/email wallet SIGNING private key
# Get it: polymarket.com → avatar → Settings → Export Private Key
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy/funder address
# Get it: polymarket.com → Deposit → copy the Polygon address shown
POLYMARKET_FUNDER_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE

# ── BUILDER / RELAYER (for auto-redeem) ──────────────────────────
# Required for automatic redemption of winning positions.
# These are the credentials from your Polymarket Builder account.
# Your env shows them as RELAYER_API_KEY / RELAYER_API_KEY_ADDRESS —
# map them as follows:
#
#   RELAYER_API_KEY          → BUILDER_KEY
#   (your signer address)    → used internally — no separate var needed
#   BUILDER_SECRET           → from your Builder dashboard
#   BUILDER_PASSPHRASE       → from your Builder dashboard
#
# Without these the bot still trades normally; wins just settle
# on-chain automatically within ~5 min (visible after UI refresh).
BUILDER_KEY=YOUR_RELAYER_API_KEY_HERE
BUILDER_SECRET=YOUR_BUILDER_SECRET_HERE
BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE_HERE

# ── DASHBOARD ────────────────────────────────────────────────────
DASH_USER=admin
DASH_PASS=change_this_to_a_strong_password
DASH_PORT=8080
