# ─────────────────────────────────────────────────────────────────
# Polymarket Bot v5 — Environment Variables
# cp .env.example .env  →  fill in values  →  never commit .env
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_FUNDER_ADDRESS=0xYOUR_PROXY_ADDRESS_HERE

# ── BUILDER CREDENTIALS (required for auto-redeem) ───────────────
# Get from: polymarket.com/settings?tab=builder → "Builder Codes"
# Click "+ Create New" then copy all three values shown ONCE.
# These are NOT the same as your Relayer API Keys.
BUILDER_KEY=019cee25-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BUILDER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BUILDER_PASSPHRASE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DASHBOARD ────────────────────────────────────────────────────
DASH_USER=admin
DASH_PASS=change_this_to_a_strong_password
DASH_PORT=8080